# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
pip-wheel-metadata/
*.manifest
*.spec

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env.bak

# ---------------------------------------------------------------------------
# Environment variables  ← NEVER commit the real .env
# ---------------------------------------------------------------------------
.env

# ---------------------------------------------------------------------------
# Flask / Werkzeug
# ---------------------------------------------------------------------------
instance/
.flask_session/
flask_session/

# ---------------------------------------------------------------------------
# Testing & coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
nosetests.xml
coverage.xml
*.cover

# ---------------------------------------------------------------------------
# Type checkers / linters
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.dmypy.json
dmypy.json

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# NOTE: .dockerignore is intentionally NOT listed here – it must be committed
# so that Docker builds work correctly on every machine / CI environment.
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Logs & databases
# ---------------------------------------------------------------------------
*.log
*.sqlite3
*.db
