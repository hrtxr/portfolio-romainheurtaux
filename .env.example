# ---------------------------------------------------------------------------
# Portfolio – Environment Variables
# ---------------------------------------------------------------------------
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# Flask application entrypoint (points to run.py after refactoring)
FLASK_APP=run.py

# 'development' enables the debug server / reloader; use 'production' elsewhere
FLASK_ENV=production

# Strong random secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-very-secret-key-here

# Port the app listens on (default: 5000)
PORT=5000
